generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Pillar {
  HEALTH
  MONEY
}

enum TaskFrequency {
  DAILY
  WEEKLY
  ONE_TIME
}

enum TaskStatus {
  PENDING
  COMPLETE
  SKIPPED
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum ActivityKind {
  STRENGTH
  CARDIO
  SPORT
  SOCIAL
  SIDE_INCOME
  MAIN_INCOME
  BUSINESS
}

enum RunTrainingType {
  EASY
  LONG
  TEMPO
  INTERVAL
  FARTLEK
  RECOVERY
  RACE
  GENERIC
}

enum ExerciseMetric {
  REPS
  TIME
}

model Profile {
  id                String             @id
  email             String             @unique
  name              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  goals             Goal[]
  tasks             Task[]
  taskLogs          TaskLog[]
  taskDayOrders     TaskDayOrder[]
  workoutSessions   WorkoutSession[]
  dietLogs          DietLog[]
  bodyMetrics       BodyMetric[]
  socialMetrics     SocialMetric[]
  incomeEntries     IncomeEntry[]
  businessMetrics   BusinessMetric[]
  activityTypes     ActivityType[]
  onboardingSession OnboardingSession?
}

model OnboardingSession {
  id         String   @id @default(cuid())
  profileId  String   @unique
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  messages   Json
  isComplete Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Goal {
  id             String        @id @default(cuid())
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  pillar         Pillar
  title          String
  description    String?
  targetDate     DateTime?
  targetValue    Float?
  currentValue   Float?
  startValue     Float?
  unit           String?
  metricKey      String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tasks          Task[]

  @@index([profileId, activityTypeId])
}

model Task {
  id             String         @id @default(cuid())
  profileId      String
  profile        Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  goalId         String?
  goal           Goal?          @relation(fields: [goalId], references: [id], onDelete: SetNull)
  activityTypeId String?
  activityType   ActivityType?  @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  pillar         Pillar
  title          String
  description    String?
  frequency      TaskFrequency
  scheduledAt    DateTime?
  dayOfWeek      Int[]
  durationMin    Int?
  startMinute    Int?
  isAiGenerated  Boolean        @default(false)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  taskLogs       TaskLog[]
  dayOrders      TaskDayOrder[]

  @@index([profileId, activityTypeId])
}

model TaskDayOrder {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date      DateTime
  sortOrder Int

  @@unique([taskId, date])
  @@index([profileId, date])
}

model TaskLog {
  id        String     @id @default(cuid())
  profileId String
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date      DateTime
  status    TaskStatus @default(PENDING)
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([taskId, date])
}

model ActivityType {
  id              String           @id @default(cuid())
  profileId       String
  profile         Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  icon            String?
  color           String?
  pillar          Pillar           @default(HEALTH)
  kind            ActivityKind
  workoutPlan     WorkoutPlan?
  sessions        WorkoutSession[]
  tasks           Task[]
  goals           Goal[]
  incomeEntries   IncomeEntry[]
  socialMetrics   SocialMetric[]
  businessMetrics BusinessMetric[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([profileId, slug])
  @@index([profileId, pillar])
}

model WorkoutPlan {
  id             String           @id @default(cuid())
  profileId      String
  activityTypeId String           @unique
  activityType   ActivityType     @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  name           String
  days           WorkoutPlanDay[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model WorkoutPlanDay {
  id        String               @id @default(cuid())
  planId    String
  plan      WorkoutPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  label     String
  sortOrder Int                  @default(0)
  exercises WorkoutPlanExercise[]
}

model WorkoutPlanExercise {
  id          String         @id @default(cuid())
  dayId       String
  day         WorkoutPlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  name        String
  muscleGroup String
  metric      ExerciseMetric @default(REPS)
  targetSets  Int            @default(3)
  repRange    String?
  rir         Int?
  notes       String?
  sortOrder   Int            @default(0)
}

model WorkoutSession {
  id             String        @id @default(cuid())
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  date           DateTime
  type           String
  durationMin    Int?
  notes          String?
  source         String        @default("manual")
  externalId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  exercises      ExerciseSet[]
  runs           RunEntry[]

  @@unique([profileId, externalId])
}

model Exercise {
  id           String        @id @default(cuid())
  name         String        @unique
  category     String
  exerciseSets ExerciseSet[]
}

model ExerciseSet {
  id          String         @id @default(cuid())
  sessionId   String
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise       @relation(fields: [exerciseId], references: [id])
  setNumber   Int
  reps        Int?
  weightKg    Float?
  holdSeconds Int?
  notes       String?
}

model RunEntry {
  id              String           @id @default(cuid())
  sessionId       String
  session         WorkoutSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type            String
  trainingType    RunTrainingType?
  distanceKm      Float?
  durationMin     Int?
  avgPaceSecPerKm Int?
  avgHRBpm        Int?
  maxHRBpm        Int?
  calories        Int?
  elevationGainM  Int?
  avgCadence      Int?
  laps            RunLap[]
}

model RunLap {
  id              String   @id @default(cuid())
  runEntryId      String
  runEntry        RunEntry @relation(fields: [runEntryId], references: [id], onDelete: Cascade)
  lapIndex        Int
  distanceM       Float?
  durationSec     Float?
  avgPaceSecPerKm Int?
  avgHRBpm        Int?
  maxHRBpm        Int?
  avgCadence      Int?
  isWork          Boolean  @default(true)
  recoverySec     Int?
}

model DietLog {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date      DateTime
  slot      MealSlot
  name      String
  kcal      Int
  proteinG  Float
  fatG      Float
  carbsG    Float
  notes     String?
  createdAt DateTime @default(now())
}

model BodyMetric {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date       DateTime
  weightKg   Float?
  bodyFatPct Float?
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  armCm      Float?
  thighCm    Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([profileId, date])
}

model SocialMetric {
  id             String        @id @default(cuid())
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  platform       String
  date           DateTime
  followerCount  Int
  videoCount     Int?
  notes          String?
  createdAt      DateTime      @default(now())

  @@unique([profileId, platform, date])
  @@index([profileId, activityTypeId])
}

model IncomeEntry {
  id             String        @id @default(cuid())
  profileId      String
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activityTypeId String?
  activityType   ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  date           DateTime
  source         String
  amountPln      Float
  description    String?
  createdAt      DateTime      @default(now())

  @@index([profileId, activityTypeId])
}

model BusinessMetric {
  id             String       @id @default(cuid())
  profileId      String
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  date           DateTime
  clients        Int?
  leads          Int?
  deals          Int?
  notes          String?
  createdAt      DateTime     @default(now())

  @@unique([activityTypeId, date])
  @@index([profileId, activityTypeId])
}
